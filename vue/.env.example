# Project-wide environment configuration example
# Copy this file to .env and adjust values for your environment

# Frontend Configuration
# IP address or hostname of ESP device during development
VITE_PROXY=192.168.1.100

# Output directory for built web files (relative to vue/)
VITE_OUTPUT_DIR=../data/www/

# Backend Configuration (PlatformIO)
# Uncomment to specify custom upload port
# UPLOAD_PORT=/dev/ttyUSB0

# Serial monitor baud rate
PLATFORMIO_MONITOR_SPEED=115200
